e.g.,

https://github.com/ahbode/svc-ads-online-search/blob/75b8b218c1103b448cdb12e822a27d71462604ab/src/__nonpublished_modules__/google-ads-puppeteer-client/src/logic/webActions/access/withNewLoggedInBrowserPage.ts#L29

```ts
import { Page } from 'puppeteer-core';
import { Procedure, ProcedureContext, ProcedureInput } from 'visualogic';
import { withExtendableCaching } from 'with-simple-caching';

import { GoogleAdsPuppeteerClientAgentOptions } from '../../../domain/constants';
import { KEEP_BROWSER_ALIVE } from '../pupetteer/getHeadlessBrowser';
import { getNewLoggedInBrowserPage } from './getNewLoggedInBrowserPage';

/**
 * run an operation with a logged in browser page
 *
 * relevance
 * - ensures that only one operation is being done at a time
 *   - prevents resource hogging (doing 100 operations in parallel can be taxing on a machine)
 *   - prevents unsupported activity (websites may be built w/ assumption that only one operation will be done per browser)
 *   - prevents suspicious activity (it may trigger alarms on the website when seeing an agent doing multiple operations in parallel)
 * - correctly gets the page from the browser
 *   - reuses the existing open browser if possible
 *   - correctly creates a new browser, if needed
 * - correctly closes the page after completion
 *   - frees up resources by closing the page after being done with it
 */
export const withNewLoggedInBrowserPage = <
  TInput,
  TContext extends {
    page: Page;
    agentOptions: GoogleAdsPuppeteerClientAgentOptions;
  },
  TOutput,
>(
  logic: Procedure<TInput, TContext, TOutput>, // (input: TInput, context: TContext) => Promise<TOutput>,
  options?: {
    /**
     * allow specifying a pagekey for reusing a page across requests, to opt into continuing from the page where another operation left off, by namespace
     *
     * relevance
     * - google-ads is a single-page-app with a large bulk data load on-page-load
     *   - initial page load is very slow
     *   - subsequent clientside navigation is fast
     * - if pages know that they're comfortable starting where another operation left off, they should be able to
     *   - for example, executeScript operation only uses one single page
     */
    reusePageKey?: string;
  },
) => {
  return async (
    input: ProcedureInput<typeof logic>,
    context: Omit<ProcedureContext<typeof logic>, 'page'>,
  ): Promise<ReturnType<typeof logic>> => {
    // within the browser bottleneck
    return context.agentOptions.browser.bottleneck.schedule(async () => {
      // get a new page
      const getNewPage = options?.reusePageKey
        ? withExtendableCaching(getNewLoggedInBrowserPage, {
            cache: context.agentOptions.browser.cache,
            serialize: {
              key: (input) =>
                [
                  // namespace the reuse-page-key
                  options.reusePageKey,

                  // to the browser login credentials this is operating under
                  JSON.stringify({
                    credentials: context.agentOptions.credentials.googleAdsUi,
                  }),

                  // and the account this is operating under
                  context.agentOptions.account.customerId,
                ].join('.'),
            },
          })
        : {
            execute: () => getNewLoggedInBrowserPage(context.agentOptions),
            invalidate: undefined,
          };
      const page = await getNewPage.execute(context.agentOptions);

      // execute the logic, w/ page input injected, and ensure to close page afterwards
      try {
        await page.bringToFront(); // bring the page to front, now that we're gonna use it (if page is not in front, chromium will not actually execute our requests against it in some cases)
        const result = await logic(input, {
          ...context,
          page,
        } as TContext); // run the request
        if (!options?.reusePageKey && !KEEP_BROWSER_ALIVE) await page.close(); // close the page if reuse key wasn't specified
        return result; // return the result
      } catch (error) {
        if (getNewPage.invalidate)
          getNewPage.invalidate({ forInput: [context.agentOptions] }); // invalidate the cached page reference if error was thrown
        if (!KEEP_BROWSER_ALIVE) await page.close(); // and close the page unless user elicitly asked to leave everything open
        throw error; // pass up the error
      }
    });
  };
};
```
