playwrite reads are going to  be slow, since browser requests are always slow

therefore, we'll need to follow remote-state cache best practices, like those established by declastruct-google-ads

for example

```ts

const registration = withRemoteStateMutationRegistration(addAdGroup, {
  name: 'addAdGroup',
});
const { execute } = registration;

export {
  execute as addAdGroup, // ensure the registered execute is called, to kickoff remote-state triggers
};

// invalidate the 'list ad groups' query, since this adds new ad groups
addTriggerToListAdGroups({
  invalidatedBy: {
    mutation: registration,
    affects: ({ mutationInput, cachedQueryKeys }) => {
      return {
        inputs: [
          [
            // invalidate searches made for this campaign
            {
              filter: {
                campaignResourceName: [
                  'customers',
                  mutationInput[1].agentOptions.account.customerId,
                  'campaigns',
                  mutationInput[0].campaignId,
                ].join('/'),
              },
            },
            mutationInput[1],
          ],
          [
            // invalidate searches made without any filter -> this new ad group will have been added
            {},
            mutationInput[1],
          ],
        ],
        keys: cachedQueryKeys.filter((key) => key.includes('limit')), // these are the list searches made with filters w/ pagination => typically includes ones that search by all
      };
    },
  },
});

// invalidate the 'list adgroup criteria' query, since this adds new adgroup criteria
addTriggerToListAdGroupCriteria({
  invalidatedBy: {
    mutation: registration,
    affects: ({ mutationInput, cachedQueryKeys }) => {
      return {
        inputs: [
          [
            // invalidate "listAdGroupCriteria" searches made without any filter -> new ones will have been added
            {},
            mutationInput[1],
          ],
        ],
        keys: [
          // invalidate the queries made for "find all" without filters and with limits
          ...cachedQueryKeys.filter((key) => key.includes('limit')),

          // invalidate the searches made for this campaign too, since it now ads it
          ...cachedQueryKeys.filter((key) =>
            key.includes(mutationInput[0].campaignId),
          ),
        ],
      };
    },
  },
});

```

check out this and other examples of how to power gets & sets w/ maximum cache on-read-hits && on-write-invalidations

at these links
- https://github.com/ahbode/svc-ads-online-search/blob/779696c63a42f410ba01167891a5d3d9f2d45dcb/src/__nonpublished_modules__/google-ads-puppeteer-client/src/logic/adsActions/adGroup/addAdGroup.ts#L190
- https://github.com/ahbode/svc-ads-online-search/blob/7bb213508e6defd420bc59b2f749004426419e38/src/__nonpublished_modules__/google-ads-puppeteer-client/src/logic/adsActions/adGroupCriterion/listAdGroupCriteria.ts#L122
- https://github.com/ahbode/svc-ads-online-search/blob/8590b2f2c1cf5a8633a1a910be3dafa391d158ab/src/__nonpublished_modules__/google-ads-puppeteer-client/src/logic/performance/withRemoteStateCaching.ts#L28-L30

though, note, with-simple-caching has been renamed to with-simple-cache

the rest of the concepts are the same!

