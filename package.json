{
  "name": "declastruct-squarespace",
  "author": "ehmpathy",
  "description": "declarative control of Squarespace constructs via declastruct",
  "version": "0.2.1",
  "repository": "ehmpathy/declastruct-squarespace",
  "homepage": "https://github.com/ehmpathy/declastruct-squarespace",
  "keywords": [
    "github",
    "declarative",
    "instructions",
    "control",
    "declastruct",
    "infrastructure-as-code",
    "resources-as-code"
  ],
  "bugs": "https://github.com/ehmpathy/declastruct-squarespace/issues",
  "license": "MIT",
  "main": "dist/contract/sdks/index.js",
  "engines": {
    "node": ">=8.0.0"
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build:ts": "tsc -p ./tsconfig.build.json",
    "commit:with-cli": "npx cz",
    "fix:format:biome": "biome check --write",
    "fix:format": "npm run fix:format:biome",
    "fix:lint": "biome check --write",
    "fix": "npm run fix:format && npm run fix:lint",
    "build:clean": "rm dist/ -rf",
    "build:compile": "tsc -p ./tsconfig.build.json && tsc-alias -p ./tsconfig.build.json",
    "build": "npm run build:clean && npm run build:compile && npm run build:complete --if-present",
    "test:commits": "LAST_TAG=$(git describe --tags --abbrev=0 @^ 2> /dev/null || git rev-list --max-parents=0 HEAD) && npx commitlint --from $LAST_TAG --to HEAD --verbose",
    "test:types": "tsc -p ./tsconfig.json --noEmit",
    "test:format": "npm run test:format:biome",
    "test:lint:deps": "npx depcheck -c ./.depcheckrc.yml",
    "test:format:biome": "biome format",
    "test:lint:biome": "biome check --diagnostic-level=error",
    "test:lint:biome:all": "biome check",
    "test:lint": "npm run test:lint:biome && npm run test:lint:deps",
    "test:unit": "jest -c ./jest.unit.config.ts --forceExit --verbose --passWithNoTests $([ -z $THOROUGH ] && echo '--changedSince=main')",
    "test:integration": "jest -c ./jest.integration.config.ts --forceExit --verbose --passWithNoTests $([ -z $THOROUGH ] && echo '--changedSince=main')",
    "test:acceptance:locally": "npm run build && LOCALLY=true jest -c ./jest.acceptance.config.ts --forceExit --verbose --runInBand --passWithNoTests",
    "test": "npm run test:commits && npm run test:types && npm run test:format && npm run test:lint && npm run test:unit && npm run test:integration && npm run test:acceptance:locally",
    "test:acceptance": "npm run build && jest -c ./jest.acceptance.config.ts --forceExit --verbose --runInBand --passWithNoTests",
    "test:integration:watch": "jest -c ./jest.integration.config.ts --watch",
    "test:trace": "PLAYWRIGHT_TRACE=on npm run test:integration",
    "cache:clear": "rm -rf .cache/squarespace",
    "prepush": "npm run test && npm run build",
    "prepublish": "npm run build",
    "preversion": "npm run prepush",
    "postversion": "git push origin HEAD --tags --no-verify",
    "prepare:husky": "npx husky install && chmod ug+x .husky/*",
    "prepare": "[ -e .git ] && npm run prepare:husky || exit 0 && npm run prepare:rhachet",
    "prepare:rhachet": "rhachet init --hooks --roles mechanic behaver driver reviewer librarian ergonomist architect reflector dreamer dispatcher",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "bottleneck": "2.19.5",
    "domain-objects": "0.31.7",
    "hash-fns": "3.0.0",
    "helpful-errors": "1.5.3",
    "otpauth": "9.3.5",
    "playwright": "1.49.1",
    "playwright-extra": "4.3.6",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "rhachet-brains-anthropic": "0.4.0",
    "rhachet-brains-xai": "0.3.3",
    "rhachet-roles-bhrain": "0.23.12",
    "rhachet-roles-bhuild": "0.17.1",
    "simple-in-memory-cache": "0.4.0",
    "simple-on-disk-cache": "1.7.3",
    "type-fns": "1.21.0",
    "with-remote-state-cache": "1.3.12",
    "with-simple-cache": "0.15.3",
    "wrapper-fns": "1.1.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "@playwright/test": "1.49.1",
    "@swc/core": "1.15.3",
    "@swc/jest": "0.2.39",
    "@tsconfig/node20": "20.1.5",
    "@tsconfig/strictest": "2.0.5",
    "@types/jest": "30.0.0",
    "@types/node": "22.15.21",
    "cz-conventional-changelog": "3.3.0",
    "declapract": "0.13.1",
    "declapract-typescript-ehmpathy": "0.45.5",
    "declastruct": "1.7.3",
    "declastruct-github": "1.0.7",
    "depcheck": "1.4.3",
    "esbuild-register": "3.6.0",
    "husky": "8.0.3",
    "jest": "30.2.0",
    "rhachet": "1.39.11",
    "rhachet-roles-ehmpathy": "1.34.27",
    "test-fns": "1.7.2",
    "tsc-alias": "1.8.10",
    "tsx": "4.20.6",
    "typescript": "5.4.5"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "packageManager": "pnpm@10.24.0"
}
